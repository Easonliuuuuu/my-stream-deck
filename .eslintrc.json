{
  "root": true,
  "extends": "eslint:recommended",
  "ignorePatterns": ["client/vendor/**"],
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
  },
  "overrides": [
    {
      "files": ["server/**/*.js"],
      "env": {
        "node": true,
        "es2022": true
      }
    },
    {
      "files": ["client/sw.js"],
      "env": {
        "serviceworker": true,
        "es2022": true
      }
    },
    {
      "files": ["client/*.js"],
      "excludedFiles": ["client/sw.js"],
      "env": {
        "browser": true,
        "es2022": true
      },
      "globals": {
        "NoSleep": "readonly"
      }
    },
    {
      "files": ["client/test/**/*.js"],
      "env": {
        "node": true,
        "browser": true,
        "es2022": true
      }
    }
  ]
}
